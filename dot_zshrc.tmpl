{{- $profileName := includeTemplate "profile-name.tmpl" . | trim -}}
{{- $profile := index .profiles $profileName -}}
{{- $onepasswordAgent := includeTemplate "onepassword-agent.tmpl" . | trim -}}
# ~/.zshrc: interactive shell configuration (macOS)

# History
HISTFILE=~/.zsh_history
HISTSIZE=5000
SAVEHIST=20000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY

# Path
typeset -U path
if [[ "${XAVUGA_MISE_STARTUP:-0}" == "1" ]]; then
    path=("$HOME/.local/share/mise/shims" "$HOME/.local/bin" "$HOME/bin" $path)
else
    path=("$HOME/.local/bin" "$HOME/bin" $path)
fi

# Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias gs='git status -sb'

export XAVUGA_PROFILE="{{ $profileName }}"
export XAVUGA_MACHINE_ROLE="{{ $profile.machine_role }}"
export XAVUGA_REPO_ROOT_DAISYCHAIN="$HOME/{{ includeTemplate "context-repo-root-daisychain.tmpl" . | trim }}"
export XAVUGA_REPO_ROOT_OTHER_PROJECTS="$HOME/{{ includeTemplate "context-repo-root-other_projects.tmpl" . | trim }}"
export XAVUGA_REPO_ROOT_PROXIMA="$HOME/{{ includeTemplate "context-repo-root-proxima.tmpl" . | trim }}"

# gcloud config switching
alias gdc='export CLOUDSDK_ACTIVE_CONFIG_NAME={{ (index .contexts "daisychain").gcloud_config }}'
alias gpx='export CLOUDSDK_ACTIVE_CONFIG_NAME={{ (index .contexts "proxima").gcloud_config }}'

if [[ -S "{{ $onepasswordAgent }}" ]]; then
{{- if eq (includeTemplate "onepassword-enabled.tmpl" . | trim) "true" }}
    export SSH_AUTH_SOCK="{{ $onepasswordAgent }}"
{{- else }}
    unset SSH_AUTH_SOCK
    unset SSH_AGENT_PID
{{- end }}
else
    unset SSH_AUTH_SOCK
    unset SSH_AGENT_PID
fi


# pyenv
if [[ -d "$HOME/.pyenv" ]]; then
    export PYENV_ROOT="$HOME/.pyenv"
    eval "$(pyenv init -)"
fi

# mise is the managed Node/toolchain entry point. Keep it after pyenv init so
# its shims remain ahead of legacy managers and editor-bundled runtimes.
if [[ "${XAVUGA_MISE_STARTUP:-0}" == "1" ]] && (( $+commands[mise] )); then
    eval "$(mise activate zsh)"
fi

# direnv
if (( $+commands[direnv] )); then
    eval "$(direnv hook zsh)"
fi

# zoxide
if (( $+commands[zoxide] )); then
    eval "$(zoxide init zsh)"
fi

# fzf
if (( $+commands[fzf] )) && (( $+commands[fd] )); then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
fi

# Google Cloud SDK
if [[ -f "/opt/homebrew/share/google-cloud-sdk/path.zsh.inc" ]]; then
    source "/opt/homebrew/share/google-cloud-sdk/path.zsh.inc"
    source "/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc"
fi
export CLOUDSDK_PYTHON=/opt/homebrew/bin/python3.13

# curl (homebrew, newer than system)
export PATH="/opt/homebrew/opt/curl/bin:$PATH"

# WezTerm shell integration
if [[ "${TERM_PROGRAM:-}" == "WezTerm" ]]; then
    for wezterm_shell_integration in \
        "/Applications/WezTerm.app/Contents/Resources/wezterm.sh" \
        "/opt/homebrew/share/wezterm/wezterm.sh" \
        "/usr/local/share/wezterm/wezterm.sh" \
        "/usr/share/wezterm/wezterm.sh"
    do
        if [[ -r "$wezterm_shell_integration" ]]; then
            source "$wezterm_shell_integration"
            break
        fi
    done
    unset wezterm_shell_integration
fi

# iTerm2 integration
[[ -e "${HOME}/.iterm2_shell_integration.zsh" ]] && source "${HOME}/.iterm2_shell_integration.zsh"
