#!/bin/sh
set -eu

{{- $home := includeTemplate "home-dir.tmpl" . | trim }}
old_brewfile="{{ $home }}/Brewfile"
new_brewfile="{{ $home }}/.config/dev/Brewfile"

[ -f "$old_brewfile" ] || exit 0
[ -f "$new_brewfile" ] || exit 0

if cmp -s "$old_brewfile" "$new_brewfile"; then
  rm -f "$old_brewfile"
fi
