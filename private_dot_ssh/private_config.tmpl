Host *
{{- if eq (includeTemplate "onepassword-enabled.tmpl" . | trim) "true" }}
    IdentityAgent "{{ includeTemplate "onepassword-agent.tmpl" . | trim }}"
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
    AddKeysToAgent no
    UseKeychain no
{{- end }}

Host github.com
    HostName github.com
    User git
    IdentitiesOnly yes
    PreferredAuthentications publickey

Host fx
    User xavier
    RequestTTY yes
    RemoteCommand sh -lc 'if command -v tmux >/dev/null 2>&1; then exec tmux new-session -A -s main; fi; exec "${SHELL:-/bin/bash}" -l'
