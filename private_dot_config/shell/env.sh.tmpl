{{- $profileName := includeTemplate "profile-name.tmpl" . | trim -}}
{{- $profile := index .profiles $profileName -}}
{{- $onepasswordAgent := includeTemplate "onepassword-agent.tmpl" . | trim -}}
# Shared Linux shell environment.

path_prepend() {
  [ -d "$1" ] || return 0
  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1${PATH:+:$PATH}" ;;
  esac
}

if [ -n "${__DEV_SHELL_ENV_LOADED:-}" ]; then
  return 0
fi
export __DEV_SHELL_ENV_LOADED=1

if [ -d "$HOME/.pyenv" ]; then
  export PYENV_ROOT="${PYENV_ROOT:-$HOME/.pyenv}"
  path_prepend "$PYENV_ROOT/bin"
  path_prepend "$PYENV_ROOT/shims"
fi

{{ includeTemplate "dev-shell-path-prepend.sh.tmpl" . }}

export PATH
export XAVUGA_PROFILE="{{ $profileName }}"
export XAVUGA_MACHINE_ROLE="{{ $profile.machine_role }}"

if [ -S "{{ $onepasswordAgent }}" ]; then
  export SSH_AUTH_SOCK="{{ $onepasswordAgent }}"
else
  unset SSH_AUTH_SOCK
  unset SSH_AGENT_PID
fi

if [ -z "${MISE_BIN:-}" ]; then
  for candidate in "$HOME/.local/bin/mise" /usr/local/bin/mise /usr/bin/mise; do
    if [ -x "$candidate" ]; then
      export MISE_BIN="$candidate"
      break
    fi
  done
fi
