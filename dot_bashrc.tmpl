# ~/.bashrc: interactive shell configuration.

if [ -f "$HOME/.config/shell/env.sh" ]; then
  . "$HOME/.config/shell/env.sh"
fi

case $- in
  *i*) ;;
  *) return ;;
esac

if [ -n "${MISE_BIN:-}" ] && [ -x "$MISE_BIN" ]; then
  eval "$("$MISE_BIN" activate bash)"
fi

if [ -f "$HOME/.config/shell/interactive.bash.sh" ]; then
  . "$HOME/.config/shell/interactive.bash.sh"
fi
