# ~/.profile: login-shell configuration.

path_prepend() {
  [ -d "$1" ] || return 0
  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1${PATH:+:$PATH}" ;;
  esac
}

path_prepend "$HOME/bin"
path_prepend "$HOME/.local/bin"
if [ "${XAVUGA_MISE_STARTUP:-0}" = "1" ]; then
  path_prepend "$HOME/.local/share/mise/shims"
fi
export PATH

if [ -n "${BASH_VERSION:-}" ] && [ -f "$HOME/.bashrc" ]; then
  . "$HOME/.bashrc"
fi
