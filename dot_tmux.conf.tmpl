# Shared tmux baseline for local macOS users and the Linux execution host.

set -g default-terminal "tmux-256color"
set -as terminal-features ",xterm-256color:RGB,screen-256color:RGB,tmux-256color:RGB,wezterm:RGB"
set -g history-limit 100000
set -sg escape-time 0
set -g focus-events on
set -g mouse on
set -g set-clipboard on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g detach-on-destroy off
set -g status-keys vi
setw -g mode-keys vi

unbind C-b
set -g prefix C-a
bind C-a send-prefix

bind r source-file ~/.tmux.conf \; display-message "tmux config reloaded"
bind c new-window -c "#{pane_current_path}"
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind x kill-pane
bind X kill-window
bind Enter last-window
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind -r H resize-pane -L 5
bind -r J resize-pane -D 3
bind -r K resize-pane -U 3
bind -r L resize-pane -R 5

bind-key -T copy-mode-vi v send -X begin-selection
bind-key -T copy-mode-vi y send -X copy-selection-and-cancel

set -g status-style "fg=#e7dfd3,bg=#12161b"
set -g message-style "fg=#12161b,bg=#e5c07b"
set -g pane-border-style "fg=#4c566a"
set -g pane-active-border-style "fg=#81a2be"
set -g status-left-length 32
set -g status-right-length 80
set -g status-left "#[bold]{{ includeTemplate "profile-name.tmpl" . | trim }} #[default]#S "
set -g status-right "#(whoami)@#H | %Y-%m-%d %H:%M "
